# =============================================================================
# .env — Configuration for run-sitespeed.sh
# Copy this file to .env and adjust the values for your environment.
# .env is ignored by git (see .gitignore).
# =============================================================================

# Docker network of the official sitespeed.io compose stack.
# Usually the compose folder name + "_default".
# Check with: docker network ls
DOCKER_NETWORK=docker_default

# Graphite host.
# Windows (Docker Desktop): use the container IP
#   → find it with: docker network inspect docker_default
# Linux / macOS / VPS: use the service hostname
GRAPHITE_HOST=graphite

# Graphite port (default: 2003)
GRAPHITE_PORT=2003

# Number of iterations per URL.
# 3 = more statistical accuracy (slower)
# 1 = faster (less accuracy)
ITERATIONS=3
